                    <ui:Image source="project://database/Assets/GeneratedPalette.png?fileID=2800000&amp;guid=7ac11437ca238b942ac113f9dd3caaa8&amp;type=3#GeneratedPalette" name="bottom_col" style="display: none; flex-grow: 1;"/>
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement name="sliders1" class="text" style="flex-grow: 0; width: 100%; margin-right: 0; min-width: auto; flex-shrink: 0; border-top-width: 0; border-right-width: 0; border-bottom-width: 0; border-left-width: 0; border-left-color: rgb(248, 240, 240); border-right-color: rgb(248, 240, 240); border-top-color: rgb(248, 240, 240); border-bottom-color: rgb(248, 240, 240); border-top-left-radius: 0; border-top-right-radius: 0; border-bottom-right-radius: 0; border-bottom-left-radius: 0; min-height: auto; margin-bottom: 0; margin-top: 0; margin-left: 0;">
